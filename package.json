{
  "name": "shopez",
  "version": "1.0.0",
  "private": true,
  "description": "ShopEZ - Full-stack MERN e-commerce application",
  "scripts": {
    "server": "npm run dev --prefix server",
    "client": "npm run dev --prefix client",
    "dev": "concurrently -n SERVER,CLIENT -c blue,green \"npm run server\" \"npm run client\"",
    "install-all": "npm install --prefix server && npm install --prefix client",
    "seed": "npm run seed --prefix server",
    "seed:destroy": "npm run seed:destroy --prefix server",
    "build": "npm run build --prefix client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "mongoose": "^9.7.4"
  }
}
